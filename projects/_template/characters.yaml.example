# characters.yaml — usually generated by `pipeline.py` stage S2 from your novel.
# You can also write it by hand following this shape.

characters:
  - id: protagonist                           # short snake_case identifier
    name_ja: 主人公
    description_en: "..."                     # appearance only — used in every panel prompt
    outfit_en: "..."                          # default outfit; can be overridden per-scene
    voice: onyx                               # OpenAI TTS voice
    voice_instructions: null                  # null → fall back to project.narrator.instructions
    selected_candidate: null                  # set 1..4 after picking; null pauses pipeline at S4
    expressions:                              # 6 expressions for the stylesheet grid (optional)
      - neutral
      - smile
      - frown
      - laugh
      - cry
      - thoughtful
    poses:                                    # 4 poses for the turnaround sheet (optional)
      - "Front view"
      - "Three-quarter view facing left"
      - "Side profile facing left"
      - "Back view"

  - id: friend
    name_ja: 友人
    description_en: "..."
    outfit_en: "..."
    voice: echo
    voice_instructions: "Read warmly with hints of mischief."
    selected_candidate: null
