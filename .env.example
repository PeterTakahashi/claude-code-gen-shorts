# ---- 必須 ----

# Gemini 2.5 Flash Image (nanobanana) — 画像生成
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---- 任意 ----

# HeyGen Photo Avatar — ニュース系の冒頭トーキングヘッド
# 取得: https://app.heygen.com の Settings → API
HEYGEN_API_KEY=

# OpenAI (英語TTSを ChatGPT/gpt-image-1 などに切替えたいとき)
OPENAI_API_KEY=

# ElevenLabs (冒頭SFX)
ELEVENLABS_API_KEY=

# X (Twitter) API v2 — ニュース取得 (x_trending.py)
X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_SECRET_KEY=

# ---- DB (docker compose で立てる) ----
POSTGRES_USER=webtoon
POSTGRES_PASSWORD=webtoon
POSTGRES_DB=webtoon
POSTGRES_PORT=5433

# ---- Nikkei / Bloomberg 記事本文を取りたい場合のログイン情報 ----
# (Playwright プロファイルを使うので、ここに直接書かなくても yt-pw 経由で OK)
NIKKEI_EMAIL=
NIKKEI_PASSWORD=
BLOOMBERG_EMAIL=
BLOOMBERG_PASSWORD=

# ---- (オプション) Aivis のエンドポイント (デフォルト 127.0.0.1:10101) ----
# AIVIS_ENDPOINT=http://127.0.0.1:10101
